{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agentscan",
  "version": "0.2.9",
  "identifier": "com.aurokin.agentscan",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "agentscan",
        "width": 760,
        "height": 520,
        "minWidth": 420,
        "minHeight": 360,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": ["icons/icon.icns", "icons/icon.png"]
  }
}
